					Canvas.Left="0"
					Canvas.Top="3"
					Width="299"
					Height="1"
					Opacity="0.2"
					Background="Black"
				/>
				<Canvas
					Canvas.Left="0"
					Canvas.Top="4"
					Width="298"
					Height="1"
					Opacity="0.15"
					Background="Black"
				/>
				<Canvas
					Canvas.Left="0"
					Canvas.Top="5"
					Width="297"
					Height="1"
					Opacity="0.1"
					Background="Black"
				/>
				<Canvas
					Canvas.Left="0"
					Canvas.Top="6"
					Width="296"
					Height="1"
					Opacity="0.05"
					Background="Black"
				/>
