					Width="1"
					Height="13"
					Opacity="0.35"
					Background="Black"
				/>
				<Canvas
					Canvas.Left="1"
					Canvas.Top="6"
					Width="1"
					Height="12"
					Opacity="0.3"
					Background="Black"
				/>
				<Canvas
