<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="830" d:DesignHeight="48"
             x:Class="Lister.Desktop.Views.MainView.Parts.BuildButton.BadgesBuildingUserControl"
			 xmlns:vm="clr-namespace:Lister.Desktop.Views.MainView.Parts.BuildButton.ViewModel;assembly=Lister.Desktop"
			 x:DataType="vm:BadgesBuildingViewModel">
	        
	<Grid
		ColumnDefinitions="* 216 *"
		RowDefinitions="22 2 22"
		ShowGridLines="False"
		Height="48"
		ZIndex="1"
	    Margin="0,0"
		Background="#EEEEEE">

		<Button
			Name="BuildBadges"
			Classes="superButton"
			Grid.Column="1"
			Grid.Row="0"
			Grid.RowSpan="3"
			Width="200"
			Height="32"
			HorizontalAlignment="Center"
			ZIndex="2"
			IsEnabled="{Binding IsEnabled, Mode=OneWay}"
			ToolTip.HorizontalOffset="10"
			PointerPressed="RightPointerPressed">

			<Grid
				ShowGridLines="True"
				ColumnDefinitions="30 150 20">
				
				<Label
					Grid.Column="0"
					HorizontalAlignment="Center"
					HorizontalContentAlignment="Center"
					VerticalAlignment="Center"
					VerticalContentAlignment="Center"
				/>
				<Label
					Grid.Column="1"
					HorizontalAlignment="Center"
					HorizontalContentAlignment="Center"
					VerticalAlignment="Center"
					VerticalContentAlignment="Center"
				/>
			</Grid>
		</Button>

		<Border
			Grid.Column="0"
			Grid.Row="2"
			Height="24"
			CornerRadius="0,5,0,0"
			Background="#fafafa">

			<Canvas Name="LeftShadow">
				<Canvas
					Canvas.Left="0"
					Canvas.Top="0"
					Width="302"
					Height="1"
					Opacity="0.35"
					Background="Black"
				/>
				<Canvas
					Canvas.Left="0"
					Canvas.Top="1"
					Width="301"
					Height="1"
					Opacity="0.3"
					Background="Black"
				/>
