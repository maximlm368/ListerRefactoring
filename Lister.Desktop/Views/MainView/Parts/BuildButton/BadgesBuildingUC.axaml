					Height="5"
					BorderBrush="Black"
					BorderThickness="1,1,0,0"
					CornerRadius="4,0,0,0"
					Opacity="0.25"
				/>
				<Border
					Canvas.Left="3" Canvas.Top="3"
					Width="5"
					Height="5"
					BorderBrush="Black"
					BorderThickness="1,1,0,0"
					CornerRadius="3,0,0,0"
					Opacity="0.2"
				/>
				<Border
					Canvas.Left="4" Canvas.Top="4"
					Width="5"
					Height="5"
					BorderBrush="Black"
					BorderThickness="1,1,0,0"
					CornerRadius="2,0,0,0"
					Opacity="0.15"
				/>
				<Border
					Canvas.Left="5" Canvas.Top="5"
					Width="5"
