		</Border>

		<Border
			Grid.Column="1"
			Grid.Row="2"
			Height="24"
			CornerRadius="0,0,0,0"
			Background="White"
		/>
		<Border
			Grid.Column="1"
			Grid.Row="2"
			Height="24"
			CornerRadius="0,0,5,5"
			Background="#EEEEEE"
		/>
	</Grid>
