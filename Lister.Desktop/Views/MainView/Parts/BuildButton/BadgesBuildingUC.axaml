					Opacity="0.25"
				/>
				<Border
					Canvas.Left="299" Canvas.Top="3"
					Width="5"
					Height="5"
					BorderBrush="Black"
					BorderThickness="0,1,1,0"
					CornerRadius="0,3,0,0"
					Opacity="0.2"
				/>
				<Border
					Canvas.Left="298" Canvas.Top="4"
					Width="5"
					Height="5"
					BorderBrush="Black"
					BorderThickness="0,1,1,0"
					CornerRadius="0,2,0,0"
					Opacity="0.15"
				/>
				<Border
					Canvas.Left="297" Canvas.Top="5"
					Width="5"
					Height="5"
					BorderBrush="Black"
					BorderThickness="0,1,1,0"
