<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		mc:Ignorable="d" d:DesignWidth="668" d:DesignHeight="369"
		x:Class="Lister.Desktop.Views.DialogMessageWindows.PrintDialog.PrintDialog"
		xmlns:views="clr-namespace:Lister.Desktop.Views.DialogMessageWindows.PrintDialog; assembly=View"
		xmlns:vm="clr-namespace:Lister.Desktop.Views.DialogMessageWindows.PrintDialog.ViewModel"
		x:DataType="vm:PrintDialogViewModel"
		Width="668"
		Height="369"
		WindowStartupLocation="CenterOwner"
		SystemDecorations="None"
		CanResize="False">

	<UserControl
		Width="668"
		Height="369"
		BorderBrush = "gray"
        BorderThickness = "1">

		<StackPanel>

			<Label
				Classes="modalLabel"
				Content ="Настройка печати"
			/>
            <Grid 
				Margin="8,16"
				ColumnDefinitions="180 400 20"
				RowDefinitions="36 38 38 38 38 38 38">
				
				<Label
					Grid.Column="0"
					Grid.Row="0"
					Padding="10,5"
					Content="Выбор принтера"
				/>
				<ComboBox
					Name="PrinterChoosing"
					Grid.Column="1"
					Grid.Row="0"
					Foreground="Black"
					Background="White"
					FontSize="16"
					Height="32"
					Width="461"
					Margin="0,2"
					MaxDropDownHeight="120"
					SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}"
					ItemsSource="{Binding Printers, Mode=OneWay}">

					<ComboBox.ItemTemplate >
						<DataTemplate >
							<Label
								Classes="narrow"
								Width="420"
								VerticalContentAlignment="Center"
								Content="{Binding StringPresentation, Mode=OneWay}"
							/>
						</DataTemplate>
					</ComboBox.ItemTemplate>
				</ComboBox>

				<TextBlock
					Classes="printErrorMessage"
					Grid.Column="1"
					Grid.Row="1"
					Padding="0,0"
					Foreground="Red"
					TextWrapping="Wrap"
					Text="{Binding PrintersEmptyError, Mode=OneWay}"
				/>
				<RadioButton
					Name="AllPages"
					GroupName="PageSelection"
					Grid.Column="0"
					Grid.Row="2"
					Margin="10,-4"
					Padding="8,-5"
					Content="Все страницы"
					FontSize="16"
				/>
				<RadioButton
					GroupName="PageSelection"
					Grid.Column="0"
					Grid.Row="3"
					Margin="10,0"
					IsChecked="{Binding IsSomePages, Mode=OneWayToSource}"
					Content="Выбор страниц"
					FontSize="16"
				/>
				<TextBox
					Name="PagesText"
					Classes="pagesAmount"
					Grid.Column="1"
					Grid.Row="3"
					Width="461"
					Margin="0,-2"
					BorderBrush="{Binding PagesBorderColor, Mode=OneWay}"
					IsEnabled="{Binding IsSomePages, Mode=OneWay}"
					LostFocus="PagesLostFocus"
					GotFocus="PagesGotFocus"
					TextChanged="PagesSetChanged"
				/>
				<TextBlock
					Name="PagesError"
					Classes="printErrorMessage"
					Grid.Column="1"
					Grid.Row="4"
					Padding="0,0"
					Foreground="Red"
					TextWrapping="Wrap"
					Text="{Binding PagesError, Mode=OneWay}"
				/>
				<Label
					Grid.Column="0"
					Grid.Row="5"
					Padding="10,8"
					Content="Количество копий"
				/>
				<TextBox
					Name="AmountText"
					Classes="pagesAmount"
					Grid.Column="1"
					Grid.Row="5"
					Width="30"
					Margin="0,4"
					BorderBrush="{Binding CopiesBorderColor, Mode=OneWay}"
					Text="{Binding Copies, Mode=OneTime}"
					LostFocus="CopiesLostFocus"
					GotFocus="CopiesGotFocus"
					TextChanged="CopiesChanged"
				/>
				<TextBlock
					Name="CopiesError"			
					Classes="printErrorMessage"
					Grid.Column="1"
					Grid.Row="6"
					Padding="0,0"
					Foreground="Red"
					TextWrapping="Wrap"
					Text="{Binding CopiesError, Mode=OneWay}"
				/>
			</Grid>

			<Canvas
				Width="666"
				Height="1"
				Margin ="0,2"
				Background ="#dcdcdc"
			/>
			<Canvas
				Width="666"
				Height="51"
				Margin ="0,-2,0,0"
				Background = "#f0f0f0">

				<Button
					Name="PrinterSettings"
					Classes="Primary"
					Padding="15,4"
					Canvas.Top="8"
					Canvas.Left="8"
					Content="Настройки принтера"
					Command="{Binding OpenPrinterSettingsCommand}"
				/>
				<Button
					Name="Print"
					Classes="Primary"
					Padding="13,4"
					Canvas.Top="8"
					Canvas.Left="453"
					Content="Печатать"
					IsEnabled="{Binding  Path = PrintingIsAvailable,  Mode=OneWay}"
					Command="{Binding PrintCommand}"
				/>
				<Button
					Name="Cancel"
					Classes="Primary"
					Padding="15,4"
					Canvas.Top="8"
					Canvas.Left="563"
					Content="Отмена"
					Command="{Binding CancelCommand}"
				/>
			</Canvas>
		</StackPanel>
	</UserControl>
</Window>
