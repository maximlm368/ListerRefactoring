<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:anim="https://github.com/whistyun/AnimatedImage.Avalonia"
             mc:Ignorable="d" d:DesignWidth="830" d:DesignHeight="500"
			 x:Class="Lister.Desktop.Views.WaitingView.WaitingViewUserControl"
			 xmlns:vm="clr-namespace:Lister.Desktop.Views.WaitingView.ViewModel;assembly=Lister.Desktop"
			 x:DataType="vm:WaitingViewModel"
			 IsVisible="{Binding CurtainIsVisible}">

	<Design.DataContext>
		<vm:WaitingViewModel/>
	</Design.DataContext>
	
	<Border
		Opacity="0.5"
		Background="Black">
		
		<Image
			Name="image"
			HorizontalAlignment="Center"
			VerticalAlignment="Center"
			anim:ImageBehavior.AnimatedSource="{Binding GifSource}"
			Opacity="2"
			Width="300"
			Height="300"
		/>
	</Border>
</UserControl>
