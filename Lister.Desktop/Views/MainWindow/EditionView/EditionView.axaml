		<Grid
			ColumnDefinitions="* 250"
			Background="#fafafa"
			Margin="0,-8"
			ZIndex="1">

			<StackPanel
				Name="ItemEditionBlock"
				Grid.Column="0"
				Orientation="Horizontal">

				<Border
					Name="EditionButtonsBlock"
					Width="232"
					Height="357"
					Margin="0,14"
					CornerRadius="0,5,5,0"
					Background="#eeeeee"
					BoxShadow="3 3 10 0 #817974"
					ZIndex="2">

					<Grid
						RowDefinitions="16 48 8 20 32 16 10 80 16 1 4 32">

						<Grid
							Name="Counter"
							ColumnDefinitions="62 158"
							RowDefinitions="24 24"
							Grid.Row="1">

							<Label
								Grid.Column="0"
								Grid.Row="0"
								Padding="16,0,4,0"
								ToolTip.Tip="Всего бейджей"
								Content="{Binding ProcessableCount, Mode=OneWay}"
							/>
							<Label
								Grid.Column="1"
								Grid.Row="0"
								Padding="4,0"
								Content="Всего бейджей"
							/>
							<Label
								Grid.Column="0"
								Grid.Row="1"
								Padding="16,0,4,0"
								Foreground="Red"
								ToolTip.Tip="Из них с ошибками"
								Content="{Binding IncorrectBadgesCount, Mode=OneWay}"
							/>
							<Label
								Grid.Column="1"
								Grid.Row="1"
								Padding="4,0"
								Content="Из них с ошибками"
							/>
						</Grid>

						<Label
							Grid.Row="3"
							Height="24"
							Margin="16,0"
							Padding="0,0"
							Content="Размер шрифта"
						/>
						<StackPanel
							Grid.Row="4"
							Orientation="Horizontal">

							<Button
								Name="ZoomOut"
								Classes="transparent"
								Margin="16,0"
								Padding="8,7"
								Width="32"
								Content="&#xf068;"
								ToolTip.Tip="Уменьшить шрифт"
								KeyDown="ChangeFocusedFontSize"
								GotFocus="ZoomOnOutGotFocus"
								LostFocus="ZoomOnOutLostFocus"
								Command="{Binding ReduceFontSize}"
								PointerPressed="SomeButtonPressed"
								IsEnabled="{Binding ZoommerIsEnable, Mode=OneWay}"
							/>
							<Label
								Name="ScalabilityGrade"
								Width="128"
								Background="{Binding FocusedFontSizeColor, Mode=OneWay}"
								BorderBrush="{Binding FocusedFontSizeBorderColor, Mode=OneWay}"
								Margin="-12,0"
								GotFocus="HandleGettingFocus"
								KeyDown="ToParticularBadge"
								Content="{Binding ProcessableBadge.FocusedFontSize, Mode=OneWay}"
								HorizontalContentAlignment="Center"
								VerticalContentAlignment="Center"
								CornerRadius = "3"
								BorderThickness="1"
								IsTabStop="False"
								Focusable="False"
								IsEnabled="{Binding ZoommerIsEnable, Mode=OneWay}"
							/>
							<Button
								Name="ZoomOn"
								Classes="transparent"
								Margin="16,0"
								Padding="7,7"
								Width="32"
								Content="&#x2b;"
								ToolTip.Tip="Увеличить шрифт"
								KeyDown="ChangeFocusedFontSize"
								GotFocus="ZoomOnOutGotFocus"
								LostFocus="ZoomOnOutLostFocus"
								Command="{Binding IncreaseFontSize}"
								PointerPressed="SomeButtonPressed"
								IsEnabled="{Binding ZoommerIsEnable, Mode=OneWay}"
							/>
						</StackPanel>

						<Label
							Grid.Row="6"
							Height="24"
							Margin="16,5"
							Padding="0,2"
							Content="Текст"
						/>
						<TextBox
							Name="EditorTextBox"
							Grid.Row="7"
							Width="200"
							Height="80"
							HorizontalAlignment="Center"
							TextWrapping="Wrap"
							IsEnabled="{Binding ZoommerIsEnable, Mode=OneWay}"
							Text="{Binding ProcessableBadge.FocusedText, Mode=OneWay}"
							KeyDown="ToParticularBadge"
							GotFocus="HandleGettingFocus"
							LostFocus="TextEditorLostFocus"
							TextChanged="HandleTextEdition"
						/>
						<Button
							Name="Spliter"
							Classes="Primary"
							Grid.Row="9"
							ToolTip.Tip="Разделить текст на слова"
							HorizontalAlignment="Center"
							Width="200"
							Height="32"
							Margin="0,17"
							Command="{Binding Split}"
							PointerPressed="SomeButtonPressed"
							KeyDown="ToParticularBadge"
							IsEnabled="{Binding SplitterIsEnable, Mode=OneWay}">

							<StackPanel Orientation="Horizontal">
								<Label
									Classes="picture"
									Content="&#xf529;"
									Width="20"
									Padding="0,8"
								/>
								<Label
									Content="Разделить"
									Width="190"
									Padding="40,6"
								/>
							</StackPanel>
						</Button>

						<Button
							Name="Cancel"
							Classes="Primary"
							Grid.Row="11"
							ToolTip.Tip="Отменить все изменения"
							Width="200"
							Height="32"
							HorizontalAlignment="Center"
							Margin="0,-11"
							IsEnabled="{Binding ProcessableBadge.IsChanged, Mode=OneWay}"
							Command="{Binding CancelChanges}"
							PointerPressed="SomeButtonPressed"
							KeyDown="ToParticularBadge">

							<StackPanel Orientation="Horizontal">
								<Label
									FontFamily="{StaticResource FA}"
									Content="&#xf2ea;"
									Width="20"
									Padding="0,8"
								/>
								<Label
									Content="Отмена"
									Width="190"
									Padding="50,6"
								/>
							</StackPanel>
						</Button>
					</Grid>
				</Border>

				<Border
					HorizontalAlignment="Left"
					Width="{Binding  Path=WorkAreaWidth,  Mode=OneWay}"
					Height="{Binding  Path=WorkAreaHeight,  Mode=OneWay}"
					Margin="-232, 0"
					BorderThickness="0">

					<ScrollViewer
						Name="Scroller"
						VerticalScrollBarVisibility="Auto"
						HorizontalScrollBarVisibility="Auto"
						AllowAutoHide="False">

						<Border
							BorderThickness="1"
							BorderBrush="Gray"
							Width="{Binding ProcessableBadge.BorderWidth, Mode=OneWay}"
							Height="{Binding ProcessableBadge.BorderHeight, Mode=OneWay}"
							VerticalAlignment="Center"
							HorizontalAlignment="Center">

							<Canvas
								Name="Badge"
								VerticalAlignment="Center"
								HorizontalAlignment="Center"
								Width="{Binding ProcessableBadge.BadgeWidth, Mode=OneWay}"
								Height="{Binding ProcessableBadge.BadgeHeight, Mode=OneWay}"
								PointerPressed="CaptureBadge">

								<Image
									Name="backgroundImage"
									Canvas.Top="0"
									Canvas.Left="0"
									Width="{Binding ProcessableBadge.BadgeWidth, Mode=OneWay}"
									Height="{Binding ProcessableBadge.BadgeHeight, Mode=OneWay}"
									VerticalAlignment="Top"
									Source = "{Binding ProcessableBadge.ImageBitmap, Mode=OneWay}"
								/>
								<ItemsControl
									Name="TextLines"
									ItemsSource="{Binding ProcessableBadge.TextLines, Mode=OneWay}">

									<ItemsControl.ItemsPanel>
										<ItemsPanelTemplate>
											<Canvas
												Width="{Binding $parent[Canvas].Width, Mode=OneWay}"
												Height="{Binding $parent[Canvas].Height, Mode=OneWay}"
											/>
										</ItemsPanelTemplate>
									</ItemsControl.ItemsPanel>

									<ItemsControl.Styles>
										<Style Selector="ItemsControl ContentPresenter" 
											   x:DataType="Badge:TextLineViewModel">
											<Setter Property="Canvas.Left" Value="{Binding LeftOffsetWithBorder, Mode=OneWay}"/>
											<Setter Property="Canvas.Top" Value="{Binding TopOffsetWithBorder, Mode=OneWay}"/>
										</Style>
									</ItemsControl.Styles>

									<ItemsControl.ItemTemplate>
										<DataTemplate>

											<Border
												x:DataType="Badge:TextLineViewModel"
												Background="{Binding Background, Mode=OneWay }"
												BorderThickness="{Binding BorderThickness, Mode=OneWay}"
												BorderBrush="{Binding BorderColor, Mode=OneWay}"
												Height="{Binding HeightWithBorder, Mode=OneWay}">

												<TextBlock
													Width="{Binding UsefullWidth, Mode=OneWay}"
													VerticalAlignment="Center"
													Padding="{Binding Padding, Mode=OneWay}"
													Height="{Binding Height, Mode=OneWay}"
													FontSize="{Binding FontSize, Mode=OneWay}"
													FontFamily="{Binding FontFamily, Mode=OneWay }"
													FontWeight="{Binding FontWeight, Mode=OneWay }"
													Foreground="{Binding Foreground, Mode=OneWay }"
													DoubleTapped="Focus"
													PointerPressed="Capture"
													PointerMoved="Move"
													PointerEntered="SetCrossCursor"
													PointerExited="SetArrowCursor"
													IsEnabled="True"
													Text="{Binding Content, Mode=OneWay }"
												/>
											</Border>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>

								<ItemsControl
									Name="images"
									ItemsSource="{Binding ProcessableBadge.InsideImages, Mode=OneWay }">

									<ItemsControl.ItemsPanel>
										<ItemsPanelTemplate>
											<Canvas
												Width="{Binding $parent[Canvas].Width, Mode=OneWay }"
												Height="{Binding $parent[Canvas].Height, Mode=OneWay }"
											/>
										</ItemsPanelTemplate>
									</ItemsControl.ItemsPanel>

									<ItemsControl.Styles>
										<Style Selector="ItemsControl ContentPresenter" 
											   x:DataType="Badge:TextLineViewModel">
											<Setter Property="Canvas.Left" Value="{Binding LeftOffsetWithBorder, Mode=OneWay}"/>
											<Setter Property="Canvas.Top" Value="{Binding TopOffsetWithBorder, Mode=OneWay}"/>
										</Style>
									</ItemsControl.Styles>

									<ItemsControl.ItemTemplate>
										<DataTemplate>

											<Border
												BorderThickness="{Binding BorderThickness, Mode=OneWay}"
												BorderBrush="{Binding BorderColor, Mode=OneWay}"
												Width="{Binding WidthWithBorder, Mode=OneWay}">

												<Image
													Source = "{Binding BitMap, Mode=OneWay }"
													Width="{Binding Width, Mode=OneWay}"
													DoubleTapped="Focus"
													PointerPressed="Capture"
													PointerMoved="Move"
													PointerEntered="SetCrossCursor"
													PointerExited="SetArrowCursor"
												/>
											</Border>
									</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>

								<ItemsControl
									Name="rects"
									ItemsSource="{Binding ProcessableBadge.InsideRectangles, Mode=OneWay }">

									<ItemsControl.ItemsPanel>
										<ItemsPanelTemplate>
											<Canvas
												Width="{Binding $parent[Canvas].Width, Mode=OneWay }"
												Height="{Binding $parent[Canvas].Height, Mode=OneWay }"
											/>
										</ItemsPanelTemplate>
									</ItemsControl.ItemsPanel>

									<ItemsControl.Styles>
										<Style Selector="ItemsControl ContentPresenter" 
											   x:DataType="Badge:TextLineViewModel">
											<Setter Property="Canvas.Left" Value="{Binding LeftOffsetWithBorder, Mode=OneWay}"/>
											<Setter Property="Canvas.Top" Value="{Binding TopOffsetWithBorder, Mode=OneWay}"/>
										</Style>
									</ItemsControl.Styles>

									<ItemsControl.ItemTemplate>
										<DataTemplate>
											<Border
												Width="{Binding WidthWithBorder, Mode=OneWay}"
												Height="{Binding HeightWithBorder, Mode=OneWay}"
												BorderThickness="{Binding BorderThickness, Mode=OneWay}"
												BorderBrush="{Binding BorderColor, Mode=OneWay}">

												<Rectangle
													Height="{Binding Height, Mode=OneWay}"
													Width="{Binding Width, Mode=OneWay}"
													Fill="{Binding FillColor, Mode=OneWay}"
													DoubleTapped="Focus"
													PointerPressed="Capture"
													PointerMoved="Move"
													PointerEntered="SetCrossCursor"
													PointerExited="SetArrowCursor"
												/>
											</Border>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>

								<ItemsControl
									Name="ellipses"
									ItemsSource="{Binding ProcessableBadge.InsideEllipses, Mode=OneWay }">

									<ItemsControl.ItemsPanel>
										<ItemsPanelTemplate>
											<Canvas
												Width="{Binding $parent[Canvas].Width, Mode=OneWay }"
												Height="{Binding $parent[Canvas].Height, Mode=OneWay }"
											/>
										</ItemsPanelTemplate>
									</ItemsControl.ItemsPanel>

									<ItemsControl.Styles>
										<Style Selector="ItemsControl ContentPresenter" 
											   x:DataType="Badge:TextLineViewModel">
											<Setter Property="Canvas.Left" Value="{Binding LeftOffsetWithBorder, Mode=OneWay}"/>
											<Setter Property="Canvas.Top" Value="{Binding TopOffsetWithBorder, Mode=OneWay}"/>
										</Style>
									</ItemsControl.Styles>

									<ItemsControl.ItemTemplate>
										<DataTemplate>
											<Border
												Width="{Binding WidthWithBorder, Mode=OneWay}"
												Height="{Binding HeightWithBorder, Mode=OneWay}"
												BorderThickness="{Binding BorderThickness, Mode=OneWay}"
												BorderBrush="{Binding BorderColor, Mode=OneWay}">

												<Ellipse
													Height="{Binding Height, Mode=OneWay}"
													Width="{Binding Width, Mode=OneWay}"
													Fill="{Binding FillColor, Mode=OneWay}"
													DoubleTapped="Focus"
													PointerPressed="Capture"
													PointerMoved="Move"
													PointerEntered="SetCrossCursor"
													PointerExited="SetArrowCursor"
												/>
											</Border>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
							</Canvas>
						</Border>
					</ScrollViewer>
				</Border>
			</StackPanel>

			<Border
				Grid.Column="1"
				Width="250"
				Margin="{Binding FilterBlockMargin, Mode=OneWay}"
				Height="392"
				CornerRadius="5,0,0,5"
				PointerWheelChanged="ScrollByWheel"
				Background="#EEEEEE"
				BoxShadow="-3 3 10 0 #817974">

				<StackPanel
					Width="248"
					Height="386">

					<Button
						Name="Extender"
						Classes="extender"
						CornerRadius="5,0,0,0"
						HorizontalAlignment="Left"
						Margin="8,6"
						Padding="4,4"
						Command="{Binding ExtendOrShrinkCollectionManagement}"
						PointerPressed="SomeButtonPressed"
						ToolTip.Tip="{Binding ExtentionTip, Mode=OneWay}"
						Content="{Binding ExtenderContent, Mode=OneWay}"
					/>
					<Border
						Height="24"
						Margin="7,5"
						KeyDown="ToParticularBadge">

						<StackPanel
							Orientation="Horizontal">

							<Button
								Name="Switcher"
								Classes="Switcher"
								Width="{Binding SwitcherWidth, Mode=OneWay}"
								Height="32"
								Margin="1,2"
								Padding="3,3"
								Focusable="{Binding FilterIsShrinked, Mode=OneWay}"
								ToolTip.Tip="{Binding SwitcherTip, Mode=OneWay}"
								Command="{Binding  Path = Filter}"
								PointerPressed="SomeButtonPressed">

								<Label
									FontFamily="{StaticResource FA}"
									FontSize="16"
									VerticalContentAlignment="Center"
									Content="&#xf0b0;"
									Foreground="{Binding SwitcherForeground, Mode=OneWay}"
								/>
							</Button>

							<Label
								Width="{Binding FilterLabelWidth, Mode=OneWay}"
								Margin="0,4"
								Padding="0, 5"
								Content="Фильтры"
							/>
							<ComboBox
								Name="FilterChoosing"
								Background="White"
								Height="32"
								Width="143"
								Margin="10,-4"
								Padding="4,1"
								MaxDropDownHeight="200"
								Focusable="{Binding FilterIsExtended, Mode=OneWay}"
								SelectedIndex="{Binding FilterSelectedIndex, Mode=OneWay}"
								SelectionChanged="SelectionChanged"
								ItemsSource="{Binding FilterNames, Mode=OneWay}">

								<ComboBox.ItemTemplate >
									<DataTemplate >
										<Label
											Classes="narrow"
											Padding="-5,2"
											Content="{Binding,  Mode=OneWay}"
										/>
									</DataTemplate>
								</ComboBox.ItemTemplate>
							</ComboBox>
						</StackPanel>
					</Border>

					<Button
						Name="Up"
						Classes="upDownArrows"
						Margin ="11,10"
						Focusable="{Binding UpDownIsFocusable, Mode=OneWay}"
						ToolTip.Tip="К предыдущему бейджу"
						IsEnabled="{Binding PreviousOnSliderIsEnable, Mode=OneWay}"
						IsVisible="{Binding UpDownIsVisible, Mode=OneWay}"
						Command="{Binding ToPrevious}"
						PointerPressed="SomeButtonPressed"
						Content="&#xf0d8;"
					/>
					<StackPanel
						Height="226"
						Margin="{Binding SliderMargin, Mode=OneWay}"
						Orientation="Horizontal">

						<ItemsControl
							Width="{Binding SliderCollectionWidth, Mode=OneWay}"
							HorizontalAlignment="Left"
							VerticalAlignment="Top"
							ItemsSource="{Binding VisibleIcons, Mode=OneWay}">

							<ItemsControl.ItemTemplate>
								<DataTemplate>

									<Border
										Grid.Column="0"
										HorizontalAlignment="Left"
										Width="{Binding Width, Mode=OneWay}"
										Height="24"
										Margin="0,2"
										BorderThickness="1"
										Tapped="ToParticularBadge"
										PointerEntered="SliderItemPointerEntered"
										PointerExited="SliderItemPointerExited">

										<Grid
											ColumnDefinitions="22 *"
											Width="{Binding InsideBorderWidth, Mode=OneWay}"
											Margin="-1,0">

											<Label
												Grid.Column="0"
												Width="22"
												Height="22"
												HorizontalContentAlignment="Center"
												VerticalContentAlignment="Center"
												FontFamily="{StaticResource FA}"
												HorizontalAlignment="Left"
												Background="{Binding Background, Mode=OneWay }"
												Foreground="{Binding CorrectnessColor, Mode=OneWay }"
												Content="{Binding CorrectnessIcon, Mode=OneWay }"
											/>
											<Label
												Grid.Column="1"
												Height="22"
												Padding="16,6,0,0"
												Background="{Binding Background, Mode=OneWay }"
												FontWeight="{Binding BoundFontWeight, Mode=OneWay }"
												FontFamily="{Binding BoundFontFamily, Mode=OneWay }"
												Content="{Binding BoundPersonName, Mode=OneWay }"
											/>
										</Grid>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>

						<Grid
							VerticalAlignment="Top"
							Margin="1,0"
							Width="{Binding ScrollWidth, Mode=OneWay}"
							Background="White">

							<Grid.RowDefinitions>
								<RowDefinition Height="15"></RowDefinition>
								<RowDefinition Height="{Binding RunnerBruttoWalkSpace, Mode=OneWay}"></RowDefinition>
								<RowDefinition Height="15"></RowDefinition>
							</Grid.RowDefinitions>

							<Button
								Name="Upper"
								Classes="scrollButton"
								Grid.Row="0"
								Width="{Binding ScrollWidth, Mode=OneWay}"
								Padding="2,2"
								Content="&#xF077;"
								Focusable="{Binding FilterIsExtended, Mode=OneWay}"
								Command="{Binding ScrollUp}"
								PointerPressed="SomeButtonPressed"
							/>
							<Canvas
								Grid.Row="1"
								Background="#EEEEEE"
								Width="{Binding ScrollWidth, Mode=OneWay}"
								Height="{Binding RunnerBruttoWalkSpace, Mode=OneWay}"
								VerticalAlignment="Center"
								Tapped="ShiftRunner">

								<Canvas
									Classes="Runner"
									Width="{Binding ScrollWidth, Mode=OneWay}"
									Height="{Binding RunnerHeight, Mode=OneWay}"
									Canvas.Left="0"
									Canvas.Top="{Binding ScrollOffset, Mode=OneWay}"
									Background="#817974"
									PointerPressed="CaptureRunner"
									PointerMoved="MoveRunner"
									PointerEntered="OverRunner"
									PointerExited="ExitedRunner"
									PointerReleased="ReleaseRunner"
								/>
							</Canvas>

							<Button
								Name="Downer"
								Classes="scrollButton"
								Grid.Row="2"
								Width="{Binding ScrollWidth, Mode=OneWay}"
								Padding="2,2"
								Focusable="{Binding FilterIsExtended, Mode=OneWay}"
								Content="&#xF078;"
								Command="{Binding ScrollDown}"
								PointerPressed="SomeButtonPressed"
							/>
						</Grid>
					</StackPanel>

					<Button
						Name="Down"
						Classes="upDownArrows"
						Margin ="11,8"
						Focusable="{Binding UpDownIsFocusable, Mode=OneWay}"
						ToolTip.Tip="К следующему бейджу"
						IsEnabled="{Binding NextOnSliderIsEnable, Mode=OneWay}"
						IsVisible="{Binding UpDownIsVisible, Mode=OneWay}"
						Command="{Binding ToNext}"
						PointerPressed="SomeButtonPressed"
						Content="&#xf0d7;"
					/>
				</StackPanel>
			</Border>
		</Grid>

		<Border
			Margin="0,8"
			BorderThickness="0"
			ZIndex="2">

			<StackPanel Name="SimpleShadow" Margin="0,-8">
				<Rectangle Width="830" Height="1" Fill="Black" Opacity="0.02"/>
				<Rectangle Width="830" Height="1" Fill="Black" Opacity="0.05"/>
				<Rectangle Width="830" Height="1" Fill="Black" Opacity="0.1"/>
				<Rectangle Width="830" Height="1" Fill="Black" Opacity="0.15"/>
				<Rectangle Width="830" Height="1" Fill="Black" Opacity="0.2"/>
				<Rectangle Width="830" Height="1" Fill="Black" Opacity="0.25"/>
				<Rectangle Width="830" Height="1" Fill="Black" Opacity="0.3"/>
				<Rectangle Width="830" Height="1" Fill="Black" Opacity="0.35"/>
			</StackPanel>
		</Border>

		<Grid
			ColumnDefinitions="* 34 34 64 60 50 34 34 * 34 64 34 4"
			Height="44"
			Margin="0,-8"
			Background="#eeeeee">

			<Button
				Name="FirstBadge"
				Classes="transparent"
				ToolTip.Tip="К первому бейджу"
				ToolTip.HorizontalOffset="20"
				Grid.Column="1"
				Width="32"
				Padding="8,6"
				Command="{Binding ToFirst}"
				PointerPressed="SomeButtonPressed"
				Content="&#xf048;"
				IsEnabled="{Binding FirstIsEnable, Mode=OneWay}"
			/>
			<Button
				Name="PreviousBadge"
				Classes="littlePicture"
				ToolTip.Tip="К предыдущему бейджу"
				ToolTip.HorizontalOffset="20"
				Grid.Column="2"
				Width="32"
				Padding="8,4"
				Command="{Binding ToPrevious}"
				PointerPressed="SomeButtonPressed"
				Content="&#xf0d9;"
				IsEnabled="{Binding PreviousIsEnable, Mode=OneWay}"
			/>
			<Label
				Width="60"
				Grid.Column="3"
				Margin="0,3"
				Padding="5,5"
				HorizontalContentAlignment="Center"
				VerticalContentAlignment="Center"
				BorderBrush="black"
				CornerRadius = "3"
				BorderThickness="1"
				Background="White"
				Content="{Binding BeingProcessedNumberText, Mode=OneWay}"
			/>
			<Label
				HorizontalContentAlignment="Center"
				VerticalContentAlignment="Center"
				Margin="0,8"
				Content="из"
				Grid.Column="4"
			/>
			<Label
				HorizontalContentAlignment="Center"
				VerticalContentAlignment="Center"
				Margin="0,9"
				Content="{Binding ProcessableCount, Mode=OneWay}"
				Grid.Column="5"
			/>
			<Button
				Name="ToNextBadge"
				Classes="littlePicture"
				ToolTip.Tip="К следующему бейджу"
				ToolTip.HorizontalOffset="20"
				Grid.Column="6"
				Width="32"
				Padding="8,4"
				Command="{Binding ToNext}"
				PointerPressed="SomeButtonPressed"
				Content="&#xf0da;"
				IsEnabled="{Binding NextIsEnable, Mode=OneWay}"
			/>
			<Button
				Name="ToLastBadge"
				Classes="transparent"
				Grid.Column="7"
				Width="32"
				Padding="8,6"
				ToolTip.Tip="К последнему бейджу"
				ToolTip.HorizontalOffset="20"
				Command="{Binding ToLast}"
				PointerPressed="SomeButtonPressed"
				Content="&#xf051;"
				IsEnabled="{Binding LastIsEnable, Mode=OneWay}"
			/>
			<Button
				Name="ZoomOutBadge"
				Classes="transparent"
				Grid.Column="9"
				HorizontalAlignment="Center"
				Width="32"
				Padding="8,6"
				IsEnabled="{Binding ZoomOutIsEnable, Mode=OneWay}"
				Command="{Binding ZoomOut}"
				PointerPressed="SomeButtonPressed"
				ToolTip.Tip="Уменьшить масштаб"
				ToolTip.VerticalOffset="-40"
				Content="&#xf068;"
			/>
			<Label
				Name="BadgeScalabilityGrade"
				Grid.Column="10"
				Width="60"
				Padding="5,5"
				HorizontalContentAlignment="Center"
				BorderBrush="black"
				CornerRadius = "3"
				BorderThickness="1"
				Background="White"
				Content="{Binding ZoomDegreeInView, Mode=OneWay}"
			/>
			<Button
				Name="ZoomOnBadge"
				Classes="transparent"
				Grid.Column="11"
				Margin="0,3"
				HorizontalAlignment="Center"
				Width="32"
				Padding="7,6"
				IsEnabled="{Binding ZoomOnIsEnable, Mode=OneWay}"
				ToolTip.Tip="Увеличить масштаб"
				ToolTip.VerticalOffset="-40"
				Command="{Binding ZoomOn}"
				PointerPressed="SomeButtonPressed"
				Content="&#x2b;"
			/>
		</Grid>

		<StackPanel
			Margin="{Binding Margin, Mode=OneWay}"
			ZIndex="10">

			<Canvas
				Width="{Binding ViewWidth, Mode=OneWay}"
				Height="{Binding ViewHeight, Mode=OneWay}"
				Opacity="0.5"
				Background="Black"
			/>
		</StackPanel>
	</StackPanel>
</UserControl>

