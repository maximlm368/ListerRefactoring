				Grid.Column="1"
				Grid.Row="2"
				Height="20"
				CornerRadius="0,0,5,5"
				Background="#EEEEEE"
			/>
		</Grid>

		<CenterShadowUc:CenterShadowUserControl
			Name="CenterShadow"
			Margin="200,-5"
			ZIndex="2"
		/>

