<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="830" d:DesignHeight="42"
             x:Class="Lister.Desktop.Views.MainWindow.MainView.Parts.NavigationZoom.NavigationZoomUserControl"
			 xmlns:vm="clr-namespace:Lister.Desktop.Views.MainWindow.MainView.Parts.NavigationZoom.ViewModel;assembly=Lister.Desktop"
			 x:DataType="vm:NavigationZoomViewModel">

	<Border>
		<Grid
			ColumnDefinitions="* 136"
			Height="42">

			<Grid
				Name="navigation"
				ColumnDefinitions="* 34 34 64 40 60 34 34 *"
				Grid.Column="0">

				<Button
					Name="firstPage"
					Grid.Column="1"
					Classes="transparent"
					Width="32"
					Padding="8,6"
					IsEnabled="{Binding FirstIsEnable, Mode=OneWay}"
					Command="{Binding ShowFirstPage}"
					PointerPressed="SomeButtonPressed"
					ToolTip.Tip="На первую страницу"
					ToolTip.HorizontalOffset="20"
					Content="&#xf048;"
				/>
				<Button
					Name="previousPage"
					Grid.Column="2"
				    Classes="littlePicture"
					Width="32"
					FontSize="20"
					Padding="8,4"
					IsEnabled="{Binding PreviousIsEnable, Mode=OneWay}"
					Command="{Binding ShowPreviousPage}"
					PointerPressed="SomeButtonPressed"
					ToolTip.Tip="На предыдущую страницу"
					ToolTip.HorizontalOffset="20"
					Content="&#xf0d9;" 
				/>
				<TextBox
					Name="visiblePageNumber"
					Grid.Column="3"
					Margin="2,3"
					Width="60"
					Height="32"
					FontSize="16"
					Background="White"
					HorizontalContentAlignment="Center"
					VerticalContentAlignment="Center"
					ScrollViewer.VerticalScrollBarVisibility="Disabled"
					ScrollViewer.HorizontalScrollBarVisibility="Disabled"
					TextChanged="StepOnPage"
					Text="{Binding VisiblePageNumber, Mode=OneWay}"
					LostFocus="PageCounterLostFocus"
				/>
				<Label
					HorizontalContentAlignment="Center"
					VerticalContentAlignment="Center"
					Margin="0,9"
					Grid.Column="4"
					Content="из"
				/>
				<Label
					HorizontalContentAlignment="Center"
					VerticalContentAlignment="Center"
					Margin="0,9"
					Grid.Column="5"
					Content="{Binding PageCount, Mode=OneWay}"
				/>
				<Button
					Name="nextPage"
					Grid.Column="6"
					Classes="littlePicture"
					Width="32"
					FontSize="20"
					Padding="8,4"
					IsEnabled="{Binding NextIsEnable, Mode=OneWay}"
					Command="{Binding ShowNextPage}"
					PointerPressed="SomeButtonPressed"
					ToolTip.Tip="На следующую страницу"
					ToolTip.HorizontalOffset="20"
					Content="&#xf0da;"
				/>
				<Button
					Name="lastPage"
					Grid.Column="7"
					Classes="transparent"
					Width="32"
					Padding="8,6"
					IsEnabled="{Binding LastIsEnable, Mode=OneWay}"
					Command="{Binding ShowLastPage}"
					PointerPressed="SomeButtonPressed"
					ToolTip.Tip="На последнюю страницу"
					ToolTip.HorizontalOffset="20"
					Content="&#xf051;"
				/>
			</Grid>
			<Grid
				Name="zoom"
				Grid.Column="1"
				ColumnDefinitions="34 64 34 4">

				<Button
					Name="zoomOut"
					Grid.Column="0"
					Classes="transparent"
					HorizontalAlignment="Center"
					Width="32"
					Padding="8,6"
					IsEnabled="{Binding ZoomOutIsEnable, Mode=OneWay}"
					Command="{Binding ZoomOut}"
					PointerPressed="SomeButtonPressed"
					ToolTip.Tip="Уменьшить масштаб"
					ToolTip.VerticalOffset="-40"
					Content="&#xf068;"
				/>
				<Label
					Name="scalabilityGrade"
					Grid.Column="1"
					Width="60"
					Padding="5,5"
					HorizontalContentAlignment="Center"
					BorderBrush="black"
					Background="White"
					CornerRadius = "3"
					BorderThickness="1"
					Content="{Binding ZoomDegreeInView, Mode=OneWay}"
				/>
				<Button
					Name="zoomOn"
					Grid.Column="2"
					Margin="0,3"
					Classes="transparent"
					HorizontalAlignment="Center"
					Width="32"
					Padding="7,6"
					IsEnabled="{Binding ZoomOnIsEnable, Mode=OneWay}"
					Command="{Binding ZoomOn}"
					PointerPressed="SomeButtonPressed"
					ToolTip.Tip="Увеличить масштаб"
					ToolTip.VerticalOffset="-40"
					Content="&#x2b;"
				/>
			</Grid>
		</Grid>
	</Border>
</UserControl>
