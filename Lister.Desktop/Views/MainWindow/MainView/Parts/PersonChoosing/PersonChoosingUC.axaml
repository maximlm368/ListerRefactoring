<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="830" d:DesignHeight="350"
			 xmlns:uc="clr-namespace:Lister.Desktop.Views.MainWindow.MainView.Parts.PersonChoosing"
			 x:Class="Lister.Desktop.Views.MainWindow.MainView.Parts.PersonChoosing.PersonChoosingUserControl"
			 xmlns:vm="clr-namespace:Lister.Desktop.Views.MainWindow.MainView.Parts.PersonChoosing.ViewModel;assembly=Lister.Desktop"
			 xmlns:modelMappings="clr-namespace:Lister.Desktop.ModelMappings;assembly=Lister.Desktop"
			 xmlns:badgeVM="clr-namespace:Lister.Desktop.ModelMappings.BadgeVM;assembly=Lister.Desktop"
			 x:DataType="vm:PersonChoosingViewModel">

	<Grid
		Name="personChoosingBlock"
		ColumnDefinitions="70 * 33 90 195"
		Background="#EEEEEE"
		Height="36"
		ZIndex="0">

		<Label
			Grid.Column="0"
			Padding="10,5"
			Content="ФИО:"
		/>
		<Canvas
			Grid.Column="1">

			<TextBox
				Name="personTextBox"
				Width="446"
				Padding="10,4"
				Margin="0,2"
				BorderThickness="1,1,0,1"
				BorderBrush="Gray"
				CornerRadius="3,0,0,3"
				ScrollViewer.VerticalScrollBarVisibility="Disabled"
				ScrollViewer.HorizontalScrollBarVisibility="Disabled"
				IsReadOnly="{Binding ChoiceIsDisabled, Mode=OneWay}"
				Focusable="{Binding ChoiceIsEnabled, Mode=OneWay}"
				Text="{Binding PlaceHolder, Mode=OneWay}"
				CaretIndex="{Binding CaretIndex, Mode=OneWay}"
				GotFocus="CustomComboboxGotFocus"
				LostFocus="CustomComboboxLostFocus"
				PointerEntered="CustomComboboxPointerOver"
				PointerExited="CustomComboboxPointerExited"
				KeyUp="HandlePersonListReduction"
				KeyDown="DropOrPickUpPersonsOrScroll"
			/>
			<Border
				Canvas.Top="36"
				ZIndex="2"
				Margin="0,-2"
				CornerRadius="0"
				BorderThickness="1"
				Opacity="{Binding DropDownOpacity, Mode=OneWay}"
				Background="Gray">

				<uc:CustomViewbox
					Name="visiblePersons"
					Width="472"
					Height="{Binding VisibleHeight, Mode=OneWay}"
					PointerWheelChanged="ScrollByWheel"
					IsScrollable="{Binding IsPersonsScrollable, Mode=OneWay}">

					<Canvas
						Name="listFrame"
						Width="472"
						Height="{Binding VisibleHeight, Mode=OneWay}"
						Background="AliceBlue">

						<Label
							Name="allPersonsSign"
							Padding="8,4"
							FontStyle="Italic"
							Background="{Binding EntireBackgroundColor, Mode=OneWay }"
							Foreground="{Binding EntireForegroundColor, Mode=OneWay }"
							BorderBrush="{Binding EntireBorderColor, Mode=OneWay }"
							FontWeight="{Binding EntireFontWeight, Mode=OneWay }"
							BorderThickness="2"
							Width="{Binding PersonListWidth, Mode=OneWay}"
							Height="{Binding FirstItemHeight, Mode=OneWay}"
							IsVisible="{Binding FirstIsVisible, Mode=OneWay}"
							PointerPressed="AcceptEntirePersonList"
							PointerEntered="HoverComboboxItem"
							PointerExited="ExitComboboxItem"
							Content="Весь список"
						/>
						<ItemsControl
							Name="personList"
							Canvas.Top="{Binding PersonsScrollValue, Mode=OneWay}"
							Width="{Binding PersonListWidth, Mode=OneWay}"
							ItemsSource="{Binding VisiblePeople, Mode=OneWay}">

							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Label
										x:DataType="badgeVM:VisiblePerson"
										Padding="8,4"
										Height="32"
										BorderThickness="1"
										Background="{Binding BackgroundColor, Mode=OneWay }"
										Foreground="{Binding ForegroundColor, Mode=OneWay }"
										BorderBrush="{Binding BorderColor, Mode=OneWay }"
										FontWeight="{Binding FontWeight, Mode=OneWay }"
										PointerPressed="HandleChoosingByTapping"
										PointerEntered="HoverComboboxItem"
										PointerExited="ExitComboboxItem"
										Content="{Binding Model.FullName, Mode=OneWay}"
									/>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>

						<Canvas
							Name="scroller"
							Canvas.Left="{Binding ScrollerCanvasLeft, Mode=OneWay}"
							Width="{Binding ScrollerWidth, Mode=OneWay}"
							Height="{Binding VisibleHeight, Mode=OneWay}"
							ZIndex="5"
							PointerPressed="ScrollerPressed"
							Background="White">

							<Canvas
								Name="upper"
								Canvas.Left="0"
								Canvas.Top="0"
								Width="{Binding ScrollerWidth, Mode=OneWay}"
								Height="15"
								Background="LightGray"
								PointerPressed="ScrollByTapping"
							/>
							<Canvas
								Name="topSpan"
								Canvas.Left="0"
								Canvas.Top="15"
								Width="{Binding ScrollerWidth, Mode=OneWay}"
								Height="{Binding TopSpanHeight, Mode=OneWay}"
								Background="#EEEEEE"
								PointerPressed="ShiftRunner"
							/>
							<Canvas
								Name="runner"
								Classes="Runner"
								Canvas.Left="0"
								Canvas.Top="{Binding RunnerYCoordinate, Mode=OneWay}"
								Width="{Binding ScrollerWidth, Mode=OneWay}"
								Height="{Binding RunnerHeight, Mode=OneWay}"
								ZIndex="3"
								Background="#817974"
								PointerPressed="CaptureRunner"
								PointerEntered="OverRunner"
								PointerExited="ExitedRunner"
								PointerMoved="MoveRunner"
							/>
							<Canvas
								Name="bottomSpan"
								Canvas.Left="0"
								Canvas.Bottom="15"
								Width="{Binding ScrollerWidth, Mode=OneWay}"
								Height="{Binding BottomSpanHeight, Mode=OneWay}"
								Background="#EEEEEE"
								PointerPressed="ShiftRunner"
							/>
							<Canvas
								Name="downer"
								Canvas.Left="0"
								Canvas.Bottom="0"
								Width="{Binding ScrollerWidth, Mode=OneWay}"
								Height="15"
								Background="LightGray"
								PointerPressed="ScrollByTapping"
							/>
						</Canvas>
					</Canvas>
				</uc:CustomViewbox>
			</Border>
		</Canvas>

		<Border
			Name="builtInBorder"
			Classes="builtIn"
			Grid.Column="2"
			Width="30"
			Height="32"
			BorderThickness="0,1,1,1"
			Background="White"
			CornerRadius="0,3,3,0">

			<Label
				Name="builtInButton"
				Classes="inBuiltIn"
				VerticalAlignment="Top"
				VerticalContentAlignment="Center"
				Width="28"
				Height="28"
				CornerRadius="0,4,4,0"
				Padding="6,7"
				PointerPressed="ButtonPressed"
				PointerReleased="ButtonReleased"
				FontFamily="{StaticResource FA}"
				Background="White"
				Content="&#xf107;"
			/>
		</Border>

		<Label
			Classes="narrow"
			Grid.Column="3"
			Content="Шаблон:"
			Margin="10, 0"
			Padding="10, 0"
		/>
		<ComboBox
			Name="templateChoosing"
			Grid.Column="4"
			PlaceholderForeground="{Binding ChosenTemplate.Color, Mode=OneWay}"
			PlaceholderText="{Binding ChosenTemplate.Name, Mode=OneWay}"
			FontSize="16"
			Height="32"
			Width="184"
			Margin="0,2"
			Padding="4,0"
			ScrollViewer.AllowAutoHide="False"
			ScrollViewer.VerticalScrollBarVisibility="Auto"
			MaxDropDownHeight="100"
			SelectedItem="{Binding ChosenTemplate, Mode=TwoWay}"
			ItemsSource="{Binding Templates, Mode=OneWay}">

			<ComboBox.ItemTemplate >
				<DataTemplate >
					<Label
						x:DataType="modelMappings:TemplateViewModel"
						Classes="narrow"
						Padding="4,0"
						Foreground="{Binding Color, Mode=OneWay}"
						Content="{Binding Name, Mode=OneWay}"
					/>
				</DataTemplate>
			</ComboBox.ItemTemplate>
		</ComboBox>
	</Grid>
</UserControl>
