<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="250" d:DesignHeight="300"
             x:Class="Lister.Desktop.Views.MainWindow.SharedComponents.ButtonsBlock.ButtonsBlockUserControl"
			 Name="Root">

    <Grid
		ColumnDefinitions="64 170">

		<Border
			Name="NarrowButtons"
			Grid.Column="0"
			Background="#EEEEEE"
			BoxShadow="3 3 10 0 #817974"
			HorizontalAlignment="Left"
			VerticalAlignment="Top"
			Width="64"
			Height="264"
			ZIndex="2"
			IsVisible="{Binding NarrowIsVisible}"
			CornerRadius="0,5,5,0">

			<Grid
				RowDefinitions="34 68 38 38 38 38 *">

				<Border
					Grid.Row="0"
					Margin="30,0"
					VerticalAlignment="Bottom"
					Width="26"
					Height="26">

					<Button
						Classes="extender"
						CornerRadius="3,5,3,3"
						Padding="4,3"
						Command="{Binding ExtendCommand}"
						PointerPressed="SomeButtonPressed"
						ToolTip.Tip="Развернуть панель"
						Content="&#xF061;"
					/>
				</Border>

				<Grid
					Grid.Row="1"
					ColumnDefinitions="64"
					RowDefinitions="30 30">

					<Label
						Grid.Column="0"
						Grid.Row="0"
						Padding="12,5"
						Width="64"
						ToolTip.Tip="Всего бейджей"
						Content="{Binding #Root.BadgeCount, Mode=OneWay}"
					/>
					<Label
						Grid.Column="0"
						Grid.Row="1"
						Padding="12,0"
						Margin="0,0,0,5"
						Width="64"
						Foreground="Red"
						ToolTip.Tip="Из них с ошибками"
						Content="{Binding #Root.IncorrectBadgeCount, Mode=OneWay}"
					/>
				</Grid>

				<Button
					Classes="Primary"
					Grid.Row="2"
					Margin="12,3"
					Padding="0,0"
					Width="32"
					Height="32"
					IsEnabled="{Binding #Root.IsButtonsEnabled, Mode=OneWay}"
					Command="{Binding EditCommand}"
					PointerPressed="SomeButtonPressed"
					ToolTip.Tip="Редактировать макет"
					ToolTip.HorizontalOffset="30">

					<StackPanel Orientation="Horizontal">
						<Label
							Classes="picture"
							Content="&#xf303;"
							Width="30"
							Padding="6,7"
						/>
						<Label
							Content="Редактировать"
							Width="170"
							Padding="13,6"
						/>
					</StackPanel>
				</Button>

				<Button
					Classes="Primary"
					Grid.Row="3"
					Margin="12,3"
					Padding="0,0"
					Width="32"
					Height="32"
					IsEnabled="{Binding #Root.IsButtonsEnabled, Mode=OneWay}"
					Command="{Binding ClearPagesCommand}"
					PointerPressed="SomeButtonPressed"
					ToolTip.Tip="Очистить макет"
					ToolTip.HorizontalOffset="30">

					<StackPanel Orientation="Horizontal">
						<Label
							Classes="picture"
							Content="&#xf51a;"
							Width="30"
							Padding="6,7"
						/>
						<Label
							Content="Очистить"
							Width="170"
							Padding="33,6"
						/>
					</StackPanel>
				</Button>

				<Button
					Classes="Primary"
					Grid.Row="4"
					Margin="12,3"
					Padding="0,0"
					Width="32"
					Height="32"
					IsEnabled="{Binding #Root.IsButtonsEnabled, Mode=OneWay}"
					Command="{Binding GeneratePdfCommand}"
					PointerPressed="SomeButtonPressed"
					ToolTip.Tip="Сохранить макет в pdf-файл"
					ToolTip.HorizontalOffset="30">

					<StackPanel Orientation="Horizontal">
						<Label
							Classes="picture"
							Content="&#xf1c1;"
							Width="30"
							Padding="6,7"
						/>
						<Label
							Content="Сохранить"
							Width="170"
							Padding="30,6"
						/>
					</StackPanel>
				</Button>

				<Button
					Classes="Primary"
					Grid.Row="5"
					Margin="12,3"
					Padding="0,0"
					Width="32"
					Height="32"
					IsEnabled="{Binding #Root.IsButtonsEnabled, Mode=OneWay}"
					Command="{Binding PrintCommand}"
					PointerPressed="SomeButtonPressed"
					ToolTip.Tip="Печатать макет"
					ToolTip.HorizontalOffset="30">

					<StackPanel Orientation="Horizontal">
						<Label
							Classes="picture"
							Content="&#xf02f;"
							Width="30"
							Padding="6,7"
						/>
						<Label
							Content="Печатать"
							Width="170"
							Padding="35,6"
						/>
					</StackPanel>
				</Button>
			</Grid>
		</Border>

		<Border
			Name="LargeButtons"
			Grid.Column="0"
			Grid.ColumnSpan="2"
			Background="#EEEEEE"
			BoxShadow="3 3 10 0 #817974"
			HorizontalAlignment="Left"
			VerticalAlignment="Top"
			Margin="0,2"
			Width="234"
			Height="264"
			ZIndex="2"
			IsVisible="{Binding LargeIsVisible}"
			CornerRadius="0,5,5,0">

			<Grid
				RowDefinitions="34 68 38 38 38 38 *">

				<Border
					Grid.Row="0"
					Margin="200,0"
					VerticalAlignment="Bottom"
					Width="26"
					Height="26">

					<Button
						Classes="extender"
						CornerRadius="3,5,3,3"
						Padding="4,3"
						Command="{Binding ShrinkCommand}"
						PointerPressed="SomeButtonPressed"
						ToolTip.Tip="Свернуть панель"
						Content="&#xF060;"
					/>
				</Border>

				<Grid
					Grid.Row="1"
					ColumnDefinitions="64 168"
					RowDefinitions="30 30">

					<Label
						Grid.Column="0"
						Grid.Row="0"
						Padding="12,5"
						Width="64"
						ToolTip.Tip="Всего бейджей"
						Content="{Binding #Root.BadgeCount, Mode=OneWay}"
					/>
					<Label
						Grid.Column="1"
						Grid.Row="0"
						Padding="0,5"
						Content="Всего бейджей"
					/>
					<Label
						Grid.Column="0"
						Grid.Row="1"
						Padding="12,0"
						Margin="0,0,0,5"
						Width="64"
						Foreground="Red"
						ToolTip.Tip="Из них с ошибками"
						Content="{Binding #Root.IncorrectBadgeCount, Mode=OneWay}"
					/>
					<Label
						Grid.Column="1"
						Grid.Row="1"
						Padding="0,0"
						Margin="0,0,0,5"
						Content="Из них с ошибками"
					/>
				</Grid>

				<Button
					Classes="Primary"
					Grid.Row="2"
					Margin="12,3"
					Padding="0,0"
					Width="200"
					Height="32"
					IsEnabled="{Binding #Root.IsButtonsEnabled, Mode=OneWay}"
					Command="{Binding EditCommand}"
					PointerPressed="SomeButtonPressed"
					ToolTip.Tip="Редактировать макет"
					ToolTip.HorizontalOffset="30">

					<StackPanel Orientation="Horizontal">
						<Label
							Classes="picture"
							Content="&#xf303;"
							Width="30"
							Padding="6,7"
						/>
						<Label
							Content="Редактировать"
							Width="170"
							Padding="13,6"
						/>
					</StackPanel>
				</Button>

				<Button
					Classes="Primary"
					Grid.Row="3"
					Margin="12,3"
					Padding="0,0"
					Width="200"
					Height="32"
					IsEnabled="{Binding #Root.IsButtonsEnabled, Mode=OneWay}"
					Command="{Binding ClearPagesCommand}"
					PointerPressed="SomeButtonPressed"
					ToolTip.Tip="Очистить макет"
					ToolTip.HorizontalOffset="30">

					<StackPanel Orientation="Horizontal">
						<Label
							Classes="picture"
							Content="&#xf51a;"
							Width="30"
							Padding="6,7"
						/>
						<Label
							Content="Очистить"
							Width="170"
							Padding="33,6"
						/>
					</StackPanel>
				</Button>

				<Button
					Classes="Primary"
					Grid.Row="4"
					Margin="12,3"
					Padding="0,0"
					Width="200"
					Height="32"
					IsEnabled="{Binding #Root.IsButtonsEnabled, Mode=OneWay}"
					Command="{Binding GeneratePdfCommand}"
					PointerPressed="SomeButtonPressed"
					ToolTip.Tip="Сохранить макет в pdf-файл"
					ToolTip.HorizontalOffset="30">

					<StackPanel Orientation="Horizontal">
						<Label
							Classes="picture"
							Content="&#xf1c1;"
							Width="30"
							Padding="6,7"
						/>
						<Label
							Content="Сохранить"
							Width="170"
							Padding="30,6"
						/>
					</StackPanel>
				</Button>

				<Button
					Classes="Primary"
					Grid.Row="5"
					Margin="12,3"
					Padding="0,0"
					Width="200"
					Height="32"
					IsEnabled="{Binding #Root.IsButtonsEnabled, Mode=OneWay}"
					Command="{Binding PrintCommand}"
					PointerPressed="SomeButtonPressed"
					ToolTip.Tip="Печатать макет"
					ToolTip.HorizontalOffset="30">

					<StackPanel Orientation="Horizontal">
						<Label
							Classes="picture"
							Content="&#xf02f;"
							Width="30"
							Padding="6,7"
						/>
						<Label
							Content="Печатать"
							Width="170"
							Padding="35,6"
						/>
					</StackPanel>
				</Button>
			</Grid>
		</Border>
	</Grid>
</UserControl>
