<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Design.PreviewWith>
    <Border Padding="20">
      <!-- Add Controls for Previewer Here -->
    </Border>
  </Design.PreviewWith>

    <Style Selector="Button.Primary /template/ ContentPresenter#PART_ContentPresenter">
		<Setter Property="Foreground" Value="#FAFAFA"/>
		<Setter Property="Background" Value="#1C547D"/>
		<Setter Property="BorderThickness" Value="2"/>
	</Style>
	<Style Selector="Button.Primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
		<Setter Property="Foreground" Value="#FAFAFA"/>
		<Setter Property="Background" Value="#1C547D"/>
		<Setter Property="BorderBrush" Value="#4AACFE"/>
	</Style>
	<Style Selector="Button.Primary:focus /template/ ContentPresenter#PART_ContentPresenter">
		<Setter Property="Foreground" Value="#FAFAFA"/>
		<Setter Property="Background" Value="#2570A7"/>
	</Style>
	<Style Selector="Button.Primary:pressed /template/ ContentPresenter#PART_ContentPresenter">
		<Setter Property="Foreground" Value="#FAFAFA"/>
		<Setter Property="Background" Value="#94BEE6"/>
	</Style>
	<Style Selector="Button.Primary:disabled /template/ ContentPresenter#PART_ContentPresenter">
		<Setter Property="Foreground" Value="#DBCAAE"/>
		<Setter Property="Background" Value="#FCF2E3"/>
	</Style>
</Styles>
